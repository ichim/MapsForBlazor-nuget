    private async Task removeAll()
    {
        if (map is null)
            return;
        await map.Geometric.Points.Remove();

    }

    private async Task update()
    {
        List<string> simulatorOnType = new List<string>() { "SigmaDrone4", "SigmaDrone2", "SigmaDrone" };

        if (map is null)
            return;
        var bounds = new DroneSimulator.Bounds(
         latMin: 45.27125785161344,    // Sud
         lonMin: 27.96145300608208,   // Vest
         latMax: 45.296145140141526,      // Nord
         lonMax: 28.00795154834795    // Est
     );


        IEnumerable<StreamPoint> points = new StreamPoints().test.Where((p) => simulatorOnType.Contains(p.type));
        if (points.Count() != 0)
        {
            foreach (StreamPoint point in points)
            {
                var droneSimulator = new DroneSimulator.DroneSimulator(bounds, point.coordinates.xy[0], point.coordinates.xy[1], timeStep: (point.value as DroneTrak).timeSpent);

                double batteryLevel = 10;

                droneSimulator.OnDroneUpdate += async (sender, e) =>
                 {
                     Random rand = new Random();
                     var state = e.State.Clone();

                     //Console.WriteLine($"DI {state.Position.Latitude} - {state.Position.Longitude}");
                     await map.Geometric.Points.Update(new List<StreamPoint>()
                                 {

                 new StreamPoint()
                 {
                     guid = point.guid,
                     type = point.type,
                     timestamp = DateTime.Now,
                     coordinates = new Coordinates()
                     {
                         xy = new double[2] { state.Position.Latitude, state.Position.Longitude }
                     },
                     value = new DroneTrak()
                     {
                         speed = state.Speed * 1000/(60*60),
                         fuel =  state.Fuel,
                       altitude =Math.Abs( state.Altitude),
                       battery = batteryLevel,
                       wifiLevel =rand.Next(0,4)

                     }
                 }

                                 });
                     {
                         batteryLevel = batteryLevel - 0.1;
                    
                     };

                 };
            }
        }

    }

    private int fuelClass(double fuel)
    {
        if (fuel < 25)
            return 0;
        else if (fuel < 50)
            return 1;
        else if (fuel < 75)
            return 2;
        else
            return 3;
    }
}

